@model UI.dto.request.NewsArticleRequestDto

@{
    ViewData["Title"] = "Create News Article";
}
<h2>Create News Article</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <!-- NewsTitle -->
    <div class="mb-3">
        <label asp-for="NewsTitle" class="form-label"></label>
        <input asp-for="NewsTitle" class="form-control" />
        <span asp-validation-for="NewsTitle" class="text-danger"></span>
    </div>

    <!-- Headline -->
    <div class="mb-3">
        <label asp-for="Headline" class="form-label"></label>
        <input asp-for="Headline" class="form-control" />
        <span asp-validation-for="Headline" class="text-danger"></span>
    </div>

    <!-- NewsContent -->
    <div class="mb-3">
        <label asp-for="NewsContent" class="form-label"></label>
        <textarea asp-for="NewsContent"
                  rows="6"
                  class="form-control"></textarea>
        <span asp-validation-for="NewsContent" class="text-danger"></span>
    </div>

    <!-- NewsSource -->
    <div class="mb-3">
        <label asp-for="NewsSource" class="form-label"></label>
        <input asp-for="NewsSource" class="form-control" />
        <span asp-validation-for="NewsSource" class="text-danger"></span>
    </div>

    <!-- Category -->
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" class="form-select">
            <option value="">-- Select Category --</option>
            @if (ViewBag.Categories != null)
            {
                @foreach (var cat in (List<UI.dto.response.CategoryResponseDto>)ViewBag.Categories)
                {
                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                }
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Tags</label>
        <select name="TagIds" class="form-select" multiple>
            @if (ViewBag.Tags != null)
            {
                @foreach (var tag in (List<UI.dto.response.TagResponseDto>)ViewBag.Tags)
                {
                    <option value="@tag.TagId">@tag.TagName</option>
                }
            }
        </select>
    </div>

    <!-- Buttons -->
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">
            Create
        </button>
        <a asp-action="Index" class="btn btn-secondary ms-2">
            Cancel
        </a>
    </div>
</form>
