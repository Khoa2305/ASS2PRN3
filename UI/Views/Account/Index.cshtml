@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Account Management";
    var accessToken = Context.Session.GetString("ACCESS_TOKEN");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Account Management</h2>
        <button class="btn btn-success" onclick="showCreateModal()">
            <i class="bi bi-person-plus"></i> Create New Account
        </button>
    </div>

    <!-- Filters & Search -->
    <div class="card shadow-sm mb-4 border-0 bg-light">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by name or email..." onkeyup="applyFilters()">
                </div>
                <div class="col-md-2">
                    <select id="roleFilter" class="form-select" onchange="applyFilters()">
                        <option value="">All Roles</option>
                        <option value="Staff">Staff</option>
                        <option value="Lecturer">Lecturer</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="pageSize" class="form-select" onchange="applyFilters()">
                        <option value="5">5 per page</option>
                        <option value="10" selected>10 per page</option>
                        <option value="20">20 per page</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="sortOrder" class="form-select" onchange="applyFilters()">
                        <option value="id_asc">Sort by ID (Asc)</option>
                        <option value="name_asc">Sort by Name (A-Z)</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div id="alertContainer"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="accountTableBody">
                        <tr><td colspan="5" class="text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <nav class="d-flex justify-content-between align-items-center mt-3">
                <small id="paginationInfo" class="text-muted"></small>
                <ul class="pagination pagination-sm mb-0" id="paginationControls"></ul>
            </nav>
        </div>
    </div>
</div>

<!-- Account Modal -->
<div class="modal fade" id="accountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Create Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="accountForm">
                    <input type="hidden" id="accountId">
                    <div class="mb-3">
                        <label for="accountName" class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="accountName" required>
                    </div>
                    <div class="mb-3">
                        <label for="accountEmail" class="form-label">Email</label>
                        <input type="email" class="form-control" id="accountEmail" required>
                    </div>
                    <div class="mb-3">
                        <label for="accountPassword" class="form-label">Password</label>
                        <input type="password" class="form-control" id="accountPassword" required>
                    </div>
                    <div class="mb-3">
                        <label for="accountRole" class="form-label">Role</label>
                        <select class="form-select" id="accountRole" required>
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveBtn" onclick="saveAccount()">Save changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE_URL = 'http://localhost:5039/api/accounts';
        const ACCESS_TOKEN = '@accessToken';

        let allAccounts = [];
        let filteredAccounts = [];
        let currentPage = 1;
        let accountModal;

        document.addEventListener('DOMContentLoaded', () => {
            accountModal = new bootstrap.Modal(document.getElementById('accountModal'));
            loadAccounts();
        });

        async function loadAccounts() {
            try {
                const response = await fetch(API_BASE_URL, {
                    headers: { 'Authorization': `Bearer ${ACCESS_TOKEN}` }
                });
                const result = await response.json();
                if (result.success) {
                    allAccounts = result.data;
                    applyFilters();
                } else {
                    showAlert(result.message || 'Failed to load accounts', 'danger');
                }
            } catch (error) { showAlert('Could not connect to API', 'danger'); }
        }

        function applyFilters() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const role = document.getElementById('roleFilter').value;
            const sort = document.getElementById('sortOrder').value;

            filteredAccounts = allAccounts.filter(acc => {
                const matchesSearch = (acc.name && acc.name.toLowerCase().includes(search)) ||
                                    (acc.email && acc.email.toLowerCase().includes(search));
                const matchesRole = !role || acc.role === role;
                return matchesSearch && matchesRole;
            });

            filteredAccounts.sort((a, b) => {
                if (sort === 'id_asc') return a.id - b.id;
                if (sort === 'name_asc') return (a.name || '').localeCompare(b.name || '');
                return 0;
            });

            currentPage = 1;
            renderTable();
        }

        function renderTable() {
            const pageSize = parseInt(document.getElementById('pageSize').value);
            const startIndex = (currentPage - 1) * pageSize;
            const endIndex = Math.min(startIndex + pageSize, filteredAccounts.length);
            const pagedItems = filteredAccounts.slice(startIndex, endIndex);

            const tbody = document.getElementById('accountTableBody');
            if (filteredAccounts.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center">No accounts found.</td></tr>';
                document.getElementById('paginationInfo').innerText = '';
                document.getElementById('paginationControls').innerHTML = '';
                return;
            }

            tbody.innerHTML = pagedItems.map(acc => `
                <tr>
                    <td>${acc.id}</td>
                    <td><strong>${acc.name}</strong></td>
                    <td>${acc.email}</td>
                    <td><span class="badge ${acc.role === 'Staff' ? 'bg-primary' : 'bg-info text-dark'}">${acc.role}</span></td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary me-1" onclick="showEditModal(${acc.id})">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteAccount(${acc.id})">Delete</button>
                    </td>
                </tr>
            `).join('');

            document.getElementById('paginationInfo').innerText = 
                `Showing ${startIndex + 1} to ${endIndex} of ${filteredAccounts.length} accounts`;
            
            renderPagination(Math.ceil(filteredAccounts.length / pageSize));
        }

        function renderPagination(totalPages) {
            const controls = document.getElementById('paginationControls');
            controls.innerHTML = '';
            if (totalPages <= 1) return;

            controls.innerHTML += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${currentPage - 1})">Prev</a></li>`;

            for(let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                    controls.innerHTML += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="changePage(${i})">${i}</a></li>`;
                }
            }

            controls.innerHTML += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${currentPage + 1})">Next</a></li>`;
        }

        function changePage(p) { currentPage = p; renderTable(); }

        function showCreateModal() {
            document.getElementById('modalTitle').innerText = 'Create Account';
            document.getElementById('accountId').value = '';
            document.getElementById('accountForm').reset();
            document.getElementById('accountPassword').required = true;
            accountModal.show();
        }

        async function showEditModal(id) {
            try {
                const response = await fetch(`${API_BASE_URL}/${id}`, {
                    headers: { 'Authorization': `Bearer ${ACCESS_TOKEN}` }
                });
                const result = await response.json();
                if (result.success) {
                    const acc = result.data;
                    document.getElementById('modalTitle').innerText = 'Edit Account';
                    document.getElementById('accountId').value = acc.id;
                    document.getElementById('accountName').value = acc.name;
                    document.getElementById('accountEmail').value = acc.email;
                    document.getElementById('accountPassword').value = acc.password || '';
                    document.getElementById('accountRole').value = acc.role;
                    document.getElementById('accountPassword').required = false;
                    accountModal.show();
                }
            } catch (error) { showAlert('Error loading account', 'danger'); }
        }

        async function saveAccount() {
            const id = document.getElementById('accountId').value;
            let data;
            if (id) {
                data = {
                    id: parseInt(id),
                    name: document.getElementById('accountName').value,
                    email: document.getElementById('accountEmail').value,
                    password: document.getElementById('accountPassword').value,
                    role: parseInt(document.getElementById('accountRole').value)
                };
            } else {
                data = {
                    accountName: document.getElementById('accountName').value,
                    accountEmail: document.getElementById('accountEmail').value,
                    accountPassword: document.getElementById('accountPassword').value,
                    accountRole: parseInt(document.getElementById('accountRole').value)
                };
            }

            try {
                const response = await fetch(API_BASE_URL, {
                    method: id ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${ACCESS_TOKEN}` },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (result.success) { accountModal.hide(); showAlert(result.message, 'success'); loadAccounts(); }
                else { showAlert(result.message, 'danger'); }
            } catch (error) { showAlert('Error saving account', 'danger'); }
        }

        async function deleteAccount(id) {
            if (!confirm('Are you sure?')) return;
            try {
                const response = await fetch(`${API_BASE_URL}/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${ACCESS_TOKEN}` }
                });
                const result = await response.json();
                if (result.success) { showAlert(result.message, 'success'); loadAccounts(); }
                else { showAlert(result.message, 'danger'); }
            } catch (error) { showAlert('Error deleting account', 'danger'); }
        }

        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show">
                ${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
            setTimeout(() => { if(container.querySelector('.alert')) container.innerHTML = ''; }, 3000);
        }
    </script>
}
