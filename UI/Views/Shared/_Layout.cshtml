@using Microsoft.AspNetCore.Http
@{
    var accessToken = Context.Session.GetString("ACCESS_TOKEN");
    var isLoggedIn = !string.IsNullOrEmpty(accessToken);
    var role = Context.Session.GetInt32("ROLE");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - FUNews</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg: linear-gradient(135deg, #020617, #0f172a);
            --glass: rgba(255, 255, 255, 0.08);
            --border: rgba(255, 255, 255, 0.15);
            --primary: #38bdf8;
            --text: #e5e7eb;
            --muted: #9ca3af;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            margin: 0;
        }

        .glass {
            background: var(--glass);
            backdrop-filter: blur(14px);
            border: 1px solid var(--border);
            border-radius: 16px;
        }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            padding: 24px;
        }

        .sidebar h4 {
            color: var(--primary);
        }

        .sidebar a {
            display: block;
            padding: 10px 14px;
            margin-bottom: 8px;
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            transition: all 0.2s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: rgba(255, 255, 255, 0.12);
            color: var(--primary);
        }

        .topbar {
            padding: 16px 24px;
            margin-bottom: 24px;
        }

        .content {
            padding: 24px;
        }

        .footer {
            color: var(--muted);
            text-align: center;
            padding: 16px;
            font-size: 14px;
        }
    </style>
</head>

<body>
<div class="d-flex">

    <!-- SIDEBAR -->
    <aside class="sidebar glass">
        <h4 class="fw-bold mb-4">
            <i class="bi bi-newspaper"></i> FUNews
        </h4>

        <!-- Home: ai cũng xem -->
        <a asp-controller="Home" asp-action="Index">
            <i class="bi bi-house"></i> Home
        </a>

            @if (isLoggedIn)
            {
                if (role == 1)
                {
                        <a asp-controller="NewsArticle" asp-action="Index">
                            <i class="bi bi-kanban"></i> Articles
                        </a>
                        <a asp-controller="Category" asp-action="Index">
                            <i class="bi bi-folder"></i> Categories
                        </a>
                        <a asp-controller="Tag" asp-action="Index">
                            <i class="bi bi-tags"></i> Tags
                        </a>
                }
                else if (role == 2)
                {
                        <!-- Chỉ Home -->
                }
                else
                {
                        <a asp-controller="NewsArticle" asp-action="Index">
                            <i class="bi bi-kanban"></i> Articles
                        </a>
                        <a asp-controller="Category" asp-action="Index">
                            <i class="bi bi-folder"></i> Categories
                        </a>
                        <a asp-controller="Tag" asp-action="Index">
                            <i class="bi bi-tags"></i> Tags
                        </a>
                        <a asp-controller="Account" asp-action="Index">
                            <i class="bi bi-people"></i> Accounts
                        </a>
                        <a asp-controller="Report" asp-action="Index">
                            <i class="bi bi-bar-chart"></i> Reports
                        </a>
                }
            }
    </aside>

    <!-- MAIN -->
    <div class="flex-grow-1">

        <!-- TOP BAR -->
        <div class="topbar glass d-flex justify-content-between align-items-center">
            <div class="fw-semibold">
                    @ViewData["Title"]
            </div>

                @if (isLoggedIn)
                {
                    <div>
                        <a asp-controller="Account" asp-action="Profile"
                           class="me-3 text-info text-decoration-none">
                            <i class="bi bi-person-circle"></i> Profile
                        </a>
                        <a asp-controller="Auth" asp-action="Logout"
                           class="btn btn-sm btn-outline-danger">
                            Logout
                        </a>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Index"
                       class="btn btn-sm btn-primary">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>
                }
        </div>

        <!-- PAGE CONTENT -->
        <main class="content">
                @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="footer">
            © 2026 FUNews Portal
        </footer>
    </div>
</div>

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
