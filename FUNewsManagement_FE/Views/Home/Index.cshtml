@{
    ViewData["Title"] = "Home Page - News Portal";
}

<div class="container-fluid p-0">
    <!-- Hero Section -->
    <div class="bg-dark text-white text-center py-5 mb-5" style="background: linear-gradient(rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.7)), url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop'); background-size: cover; background-position: center; border-bottom: 1px solid #334155;">
        <div class="py-5">
            <h1 class="display-3 fw-bold mb-3 text-white">FUNews Management System</h1>
            <p class="lead mb-4 text-light">Stay updated with the latest news from our community.</p>
        </div>
    </div>

    <div class="container">
        <!-- Search Section -->
        <div class="row justify-content-center mb-5" style="margin-top: -3rem; position: relative; z-index: 10;">
            <div class="col-md-10 col-lg-8">
                <div class="card border-0 shadow-lg" style="background: rgba(30, 41, 59, 0.95); backdrop-filter: blur(10px); border-radius: 15px; border: 1px solid rgba(255,255,255,0.1);">
                    <div class="card-body p-4">
                        <form id="searchForm" onsubmit="event.preventDefault(); loadPublicNews();">
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <label class="form-label text-muted small text-uppercase fw-bold">Search by Title</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-dark border-secondary text-secondary"><i class="bi bi-search"></i></span>
                                        <input type="text" id="searchTitle" class="form-control bg-dark border-secondary text-white" placeholder="Enter keywords...">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label text-muted small text-uppercase fw-bold">Filter by Date</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-dark border-secondary text-secondary"><i class="bi bi-calendar"></i></span>
                                        <input type="date" id="searchDate" class="form-control bg-dark border-secondary text-white">
                                    </div>
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <button type="submit" class="btn btn-info w-100 fw-bold text-dark py-2">
                                        <i class="bi bi-filter"></i> Search
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 class="fw-light border-bottom border-secondary d-inline-block pb-2 px-5 text-white">Latest News</h2>
            </div>
        </div>

        <!-- News Grid -->
        <div id="publicNewsGrid" class="row g-4 mb-5">
            <div class="col-12 text-center text-muted">
                <div class="spinner-border text-info" role="status"></div>
                <p class="mt-2">Loading latest articles...</p>
            </div>
        </div>
    </div>
</div>

<!-- Article Detail Modal -->
<div class="modal fade" id="articleDetailModal" tabindex="-1" aria-labelledby="articleDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg bg-dark-slate">
            <div class="modal-header bg-dark-header text-white border-bottom border-secondary">
                <h5 class="modal-title" id="modalTitle">Article Detail</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 p-md-5">
                <div id="modalContent">
                    <!-- Dynamic Content -->
                </div>

                <!-- Related News Section -->
                <div class="mt-5 pt-5 border-top border-secondary">
                    <h4 class="mb-4 text-info"><i class="bi bi-lightbulb"></i> Recommended For You</h4>
                    <div id="relatedNewsGrid" class="row g-3">
                        <!-- Related articles -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-dark-slate {
        background-color: #1E293B; /* Surface Color */
        color: #F8FAFC;
    }
    .bg-dark-header {
        background-color: #0F172A; /* Bg Color */
    }
    .article-card {
        background-color: #1E293B;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
        border: 1px solid #334155;
        border-radius: 15px;
        overflow: hidden;
    }
    .article-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(6, 182, 212, 0.15) !important; /* Cyan glow */
        border-color: #06B6D4;
    }
    .badge-category {
        background-color: rgba(6, 182, 212, 0.1);
        color: #06B6D4;
        font-weight: 500;
        border-radius: 5px;
    }
    #modalContent {
        color: #E2E8F0;
    }
    #modalContent img {
        max-width: 100%;
        border-radius: 10px;
        margin-bottom: 20px;
        border: 1px solid #334155;
    }
    .related-card {
        background-color: #0F172A;
        transition: transform 0.2s ease;
        cursor: pointer;
        border: 1px solid #334155;
    }
    .related-card .card-body h6 {
        color: #F1F5F9;
    }
    .related-card:hover {
        transform: scale(1.02);
        border-color: #06B6D4;
    }
    .news-content {
        color: #CBD5E1 !important;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

@section Scripts {
    <script>
        const PUBLIC_API_URL = 'http://localhost:5039/api/newsarticles/public';
        let articleModal;

        document.addEventListener('DOMContentLoaded', () => {
            articleModal = new bootstrap.Modal(document.getElementById('articleDetailModal'));
            loadPublicNews();
        });

        async function loadPublicNews() {
            try {
                const title = document.getElementById('searchTitle').value;
                const date = document.getElementById('searchDate').value;
                
                let url = new URL(PUBLIC_API_URL);
                if (title) url.searchParams.append('title', title);
                if (date) url.searchParams.append('date', date);

                const response = await fetch(url);
                const result = await response.json();
                
                const grid = document.getElementById('publicNewsGrid');
                if (result.success && result.data.length > 0) {
                    grid.innerHTML = result.data.map(article => `
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 shadow-sm article-card" onclick="viewDetail('${article.newsArticleId}')">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="badge badge-category px-2 py-1">${article.categoryName || 'General'}</span>
                                        <small class="text-muted"><i class="bi bi-calendar3"></i> ${new Date(article.createdDate).toLocaleDateString()}</small>
                                    </div>
                                    <h5 class="card-title fw-bold mb-3 text-white">${article.newsTitle}</h5>
                                    <p class="card-text text-secondary small">${article.headline ? article.headline : ''}</p>
                                </div>
                                <div class="card-footer bg-transparent border-0 pb-3">
                                    <span class="text-info fw-medium small">Read More <i class="bi bi-arrow-right"></i></span>
                                </div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    grid.innerHTML = '<div class="col-12 text-center text-muted">No articles available at the moment.</div>';
                }
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('publicNewsGrid').innerHTML = '<div class="col-12 text-center text-danger">Failed to connect to news service.</div>';
            }
        }

        async function viewDetail(id) {
            try {
                const response = await fetch(`${PUBLIC_API_URL}/${id}`);
                const result = await response.json();
                
                if (result.success) {
                    const data = result.data;
                    document.getElementById('modalTitle').innerText = data.newsTitle;
                    
                    document.getElementById('modalContent').innerHTML = `
                        <div class="mb-4">
                            <span class="badge bg-info text-dark rounded-pill px-3 py-2">${data.categoryName || 'News'}</span>
                            <span class="ms-2 text-muted"><i class="bi bi-clock"></i> ${new Date(data.createdDate).toLocaleString()}</span>
                        </div>
                        <h2 class="display-6 fw-bold mb-4 text-white">${data.newsTitle}</h2>
                        <h4 class="text-secondary fw-light mb-5 border-start border-4 border-info ps-3">${data.headline || ''}</h4>
                        <div class="news-content lead" style="white-space: pre-line; line-height: 1.8;">
                            ${data.newsContent}
                        </div>
                        <div class="mt-4 text-muted small">
                            Source: ${data.newsSource || 'Our Correspondent'}
                        </div>
                    `;

                    // Render Related Articles
                    const relatedGrid = document.getElementById('relatedNewsGrid');
                    if (data.relatedArticles && data.relatedArticles.length > 0) {
                        relatedGrid.innerHTML = data.relatedArticles.map(rel => `
                            <div class="col-md-4">
                                <div class="card h-100 related-card shadow-sm" onclick="viewDetail('${rel.newsArticleId}')">
                                    <div class="card-body p-3">
                                        <small class="text-info d-block mb-1">${rel.categoryName || ''}</small>
                                        <h6 class="card-title mb-0 text-truncate-2">${rel.newsTitle}</h6>
                                    </div>
                                </div>
                            </div>
                        `).join('');
                    } else {
                        relatedGrid.innerHTML = '<p class="text-muted small">No related articles found.</p>';
                    }

                    articleModal.show();
                }
            } catch (error) {
                console.error('Error loading detail:', error);
                alert('Could not load article detail.');
            }
        }
    </script>
}
