@using Microsoft.AspNetCore.Http
@inject FUNewsManagement_FE.Services.IOfflineStateService OfflineState
@{
    var accessToken = Context.Session.GetString("ACCESS_TOKEN");
    var isLoggedIn = !string.IsNullOrEmpty(accessToken);
    var role = Context.Session.GetInt32("ROLE");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - FUNews</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg: linear-gradient(135deg, #020617, #0f172a);
            --glass: rgba(255, 255, 255, 0.08);
            --border: rgba(255, 255, 255, 0.15);
            --primary: #38bdf8;
            --text: #e5e7eb;
            --muted: #9ca3af;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            margin: 0;
        }

        .glass {
            background: var(--glass);
            backdrop-filter: blur(14px);
            border: 1px solid var(--border);
            border-radius: 16px;
        }

        .sidebar {
            width: 260px;
            min-height: 100vh;
            padding: 24px;
        }

        .sidebar h4 {
            color: var(--primary);
        }

        .sidebar a {
            display: block;
            padding: 10px 14px;
            margin-bottom: 8px;
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            transition: all 0.2s;
        }

        .sidebar a:hover,
        .sidebar a.active {
            background: rgba(255, 255, 255, 0.12);
            color: var(--primary);
        }

        .topbar {
            padding: 16px 24px;
            margin-bottom: 24px;
        }

        .content {
            padding: 24px;
        }

        .footer {
            color: var(--muted);
            text-align: center;
            padding: 16px;
            font-size: 14px;
        }
    </style>
</head>

<body>
<div class="d-flex">

    <!-- SIDEBAR -->
    <aside class="sidebar glass">
        <h4 class="fw-bold mb-4">
            <i class="bi bi-newspaper"></i> FUNews
        </h4>

        <!-- Home: ai cũng xem -->
        <a asp-controller="Home" asp-action="Index">
            <i class="bi bi-house"></i> Home
        </a>

            @if (isLoggedIn)
            {
                if (role == 1)
                {
                        <a asp-controller="NewsArticle" asp-action="Index">
                            <i class="bi bi-kanban"></i> Articles
                        </a>
                        <a asp-controller="Category" asp-action="Index">
                            <i class="bi bi-folder"></i> Categories
                        </a>
                        <a asp-controller="Tag" asp-action="Index">
                            <i class="bi bi-tags"></i> Tags
                        </a>
                }
                else if (role == 2)
                {
                        <!-- Chỉ Home -->
                }
                else
                {
                        <a asp-controller="NewsArticle" asp-action="Index">
                            <i class="bi bi-kanban"></i> Articles
                        </a>
                        <a asp-controller="Category" asp-action="Index">
                            <i class="bi bi-folder"></i> Categories
                        </a>
                        <a asp-controller="Tag" asp-action="Index">
                            <i class="bi bi-tags"></i> Tags
                        </a>
                        <a asp-controller="Account" asp-action="Index">
                            <i class="bi bi-people"></i> Accounts
                        </a>
                        <a asp-controller="Report" asp-action="Index">
                            <i class="bi bi-bar-chart"></i> Reports
                        </a>
                }
            }
    </aside>

    <!-- MAIN -->
    <div class="flex-grow-1 d-flex flex-column h-100">

        @if (OfflineState.IsOffline)
        {
            <div class="alert alert-warning text-center rounded-0 mb-0 shadow-sm border-0 border-bottom border-warning" role="alert">
                <i class="bi bi-wifi-off me-2 fw-bold text-danger"></i>
                <strong>Offline Mode Active:</strong> Unable to connect to backend services. Viewing cached data only. Creating, updating, or deleting data is disabled.
            </div>
        }

        <!-- TOP BAR -->
        <div class="topbar glass d-flex justify-content-between align-items-center">
            <div class="fw-semibold">
                    @ViewData["Title"]
            </div>

                @if (isLoggedIn)
                {
                    <div class="d-flex align-items-center">
                        <div class="dropdown me-3">
                            <a href="#" class="text-info text-decoration-none position-relative" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bell fs-5"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge" style="display: none;">
                                    0
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="notificationDropdown" id="notificationList" style="width: 300px; max-height: 400px; overflow-y: auto;">
                                <li><span class="dropdown-item text-muted">No new notifications</span></li>
                            </ul>
                        </div>
                        <a asp-controller="Account" asp-action="Profile"
                           class="me-3 text-info text-decoration-none">
                            <i class="bi bi-person-circle"></i> Profile
                        </a>
                        <a asp-controller="Auth" asp-action="Logout"
                           class="btn btn-sm btn-outline-danger">
                            Logout
                        </a>
                    </div>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Index"
                       class="btn btn-sm btn-primary">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>
                }
        </div>

        <!-- PAGE CONTENT -->
        <main class="content">
                @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="footer">
            © 2026 FUNews Portal
        </footer>
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer" style="z-index: 1055;">
</div>

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let notifications = [];
        let unreadCount = 0;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5039/hubs/notifications")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (msg) {
            // Update Array (Keep last 10)
            notifications.unshift(msg);
            if (notifications.length > 10) notifications.pop();
            unreadCount++;

            // Trigger Toast
            showToast(msg);

            // Update UI
            updateNotificationUI();
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });

        function showToast(msg) {
            const toastHtml = `
                <div class="toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
                    <div class="toast-header bg-primary text-white">
                        <i class="bi bi-bell-fill me-2"></i>
                        <strong class="me-auto">New Article Published!</strong>
                        <small>${msg.time}</small>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                    <div class="toast-body text-dark bg-white">
                        <strong>${msg.title}</strong> by ${msg.author}
                    </div>
                </div>
            `;
            const container = document.getElementById("toastContainer");
            container.insertAdjacentHTML('beforeend', toastHtml);
            const toastEl = container.lastElementChild;
            const bsToast = new bootstrap.Toast(toastEl);
            bsToast.show();

            // Auto remove node after hidden
            toastEl.addEventListener('hidden.bs.toast', () => {
                toastEl.remove();
            });
        }

        function updateNotificationUI() {
            const badge = document.getElementById("notificationBadge");
            const list = document.getElementById("notificationList");

            if (unreadCount > 0) {
                badge.style.display = "inline-block";
                badge.innerText = unreadCount;
            } else {
                badge.style.display = "none";
            }

            if (notifications.length === 0) {
                list.innerHTML = '<li><span class="dropdown-item text-muted">No new notifications</span></li>';
            } else {
                list.innerHTML = notifications.map(n => `
                    <li>
                        <a class="dropdown-item" href="#">
                            <div class="fw-bold text-truncate" style="max-width: 250px;">${n.title}</div>
                            <div class="text-muted small">By ${n.author} - ${n.time}</div>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                `).join('');
                
                // Add mark all read button if any
                if (unreadCount > 0) {
                    list.innerHTML += '<li><a class="dropdown-item text-center text-primary fw-bold" href="#" id="markAllRead">Mark all as read</a></li>';
                    document.getElementById("markAllRead").addEventListener("click", function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        unreadCount = 0;
                        updateNotificationUI();
                    });
                }
            }
        }

        // Reset badge when opening dropdown
        document.getElementById("notificationDropdown")?.addEventListener("show.bs.dropdown", function() {
            unreadCount = 0;
            updateNotificationUI();
        });
    });
</script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
