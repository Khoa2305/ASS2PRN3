@model UI.dto.request.NewsArticleRequestDto

@{
    ViewData["Title"] = "Create News Article";
}
<h2>Create News Article</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <!-- NewsTitle -->
    <div class="mb-3">
        <label asp-for="NewsTitle" class="form-label"></label>
        <input asp-for="NewsTitle" class="form-control" />
        <span asp-validation-for="NewsTitle" class="text-danger"></span>
    </div>

    <!-- Headline -->
    <div class="mb-3">
        <label asp-for="Headline" class="form-label"></label>
        <input asp-for="Headline" class="form-control" />
        <span asp-validation-for="Headline" class="text-danger"></span>
    </div>

    <!-- NewsContent -->
    <div class="mb-3">
        <label asp-for="NewsContent" class="form-label"></label>
        <textarea asp-for="NewsContent"
                  rows="6"
                  class="form-control"></textarea>
        <span asp-validation-for="NewsContent" class="text-danger"></span>
    </div>

    <!-- NewsSource -->
    <div class="mb-3">
        <label asp-for="NewsSource" class="form-label"></label>
        <input asp-for="NewsSource" class="form-control" />
        <span asp-validation-for="NewsSource" class="text-danger"></span>
    </div>

    <!-- Category -->
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" class="form-select">
            <option value="">-- Select Category --</option>
            @if (ViewBag.Categories != null)
            {
                @foreach (var cat in (List<UI.dto.response.CategoryResponseDto>)ViewBag.Categories)
                {
                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                }
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Tags</label>
        <div class="d-flex align-items-center mb-2">
            <select name="TagIds" id="TagIds" class="form-select me-2" multiple>
                @if (ViewBag.Tags != null)
                {
                    @foreach (var tag in (List<UI.dto.response.TagResponseDto>)ViewBag.Tags)
                    {
                        <option value="@tag.TagId">@tag.TagName</option>
                    }
                }
            </select>
            <button type="button" id="btnSuggestTags" class="btn btn-outline-info text-nowrap">
                <i class="bi bi-magic"></i> Suggest Tags
            </button>
        </div>
        <div id="suggestedTagsContainer" class="d-flex flex-wrap gap-2 mt-2">
            <!-- Badges will be injected here -->
        </div>
    </div>
            {
                @foreach (var tag in (List<UI.dto.response.TagResponseDto>)ViewBag.Tags)
                {
                    <option value="@tag.TagId">@tag.TagName</option>
                }
            }
        </select>
    </div>

    <!-- Buttons -->
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">
            Create
        </button>
        <a asp-action="Index" class="btn btn-secondary ms-2">
            Cancel
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('btnSuggestTags').addEventListener('click', async function () {
            const content = document.getElementById('NewsContent').value;
            const container = document.getElementById('suggestedTagsContainer');
            const btn = document.getElementById('btnSuggestTags');

            if (!content || content.trim().length === 0) {
                alert("Please enter some News Content first so AI can extract tags.");
                return;
            }

            // UI Loading state
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Thinking...';
            btn.disabled = true;
            container.innerHTML = '';

            try {
                const response = await fetch('/AIProxy/SuggestTags', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: content })
                });

                const result = await response.json();

                if (result.success && result.data && result.data.length > 0) {
                    result.data.forEach(tag => {
                        const badge = document.createElement('span');
                        badge.className = 'badge bg-primary text-white p-2" style="cursor: pointer; transition: 0.2s;';
                        badge.innerHTML = `<i class="bi bi-tag-fill"></i> ${tag.name} <small class="text-white-50">(${(tag.confidence * 100).toFixed(0)}%)</small>`;
                        
                        badge.onclick = function () {
                            // Find the option in the multi-select
                            const selectObj = document.getElementById('TagIds');
                            let found = false;
                            for (let i = 0; i < selectObj.options.length; i++) {
                                if (selectObj.options[i].text.toLowerCase() === tag.name.toLowerCase()) {
                                    selectObj.options[i].selected = true;
                                    found = true;
                                    break;
                                }
                            }
                            
                            if (found) {
                                badge.className = 'badge bg-secondary text-white p-2';
                                badge.innerHTML = `<i class="bi bi-check-circle-fill"></i> ${tag.name} (Added)`;
                                badge.onclick = null; // Disable clicking again
                                badge.style.cursor = 'default';
                            } else {
                                alert(`The tag "${tag.name}" does not exist in the system yet. Please create it manually if needed.`);
                            }
                        };
                        container.appendChild(badge);
                    });
                } else {
                    container.innerHTML = `<span class="text-muted small">No tags suggested. Try adding more content.</span>`;
                }
            } catch (error) {
                console.error("AI Tag Suggestion Error", error);
                alert("An error occurred while communicating with the AI API.");
            } finally {
                // Reset UI
                btn.innerHTML = '<i class="bi bi-magic"></i> Suggest Tags';
                btn.disabled = false;
            }
        });
    </script>
}
