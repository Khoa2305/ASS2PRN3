@using Microsoft.AspNetCore.Http
@inject FUNewsManagement_FE.Services.IOfflineStateService OfflineState
@{
    ViewData["Title"] = "News Articles";
    var accessToken = Context.Session.GetString("ACCESS_TOKEN");
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>News Articles</h2>
        @if (!OfflineState.IsOffline)
        {
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Create New Article
            </a>
        }
    </div>

    <!-- Search & Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by title, headline...">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Sort Order</label>
                    <select id="sortOrder" class="form-select">
                        <option value="date_desc">Date (Newest First)</option>
                        <option value="date_asc">Date (Oldest First)</option>
                        <option value="title_asc">Title (A-Z)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Items per page</label>
                    <select id="pageSize" class="form-select">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100" onclick="applyFilters()">
                        <i class="bi bi-search"></i> Apply
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="alertContainer"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            
                            <th>ID</th>
                            <th>Title</th>
                            <th>Headline</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Created By</th>
                            <th>Created Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="articleTableBody">
                        <tr><td colspan="8" class="text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <nav class="d-flex justify-content-between align-items-center mt-3">
                <div id="paginationInfo">Showing 0 to 0 of 0 entries</div>
                <ul class="pagination mb-0" id="paginationControls">
                    <!-- Pagination buttons will be injected here -->
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_URL = 'http://localhost:5039/odata/NewsArticles';
        const ACCESS_TOKEN = '@accessToken';

        let allArticles = [];
        let filteredArticles = [];
        let currentPage = 1;

        document.addEventListener('DOMContentLoaded', () => {
            loadArticles();

            // Auto-filter on some inputs
            document.getElementById('searchInput').addEventListener('keyup', (e) => {
                if (e.key === 'Enter') applyFilters();
            });
        });

        async function loadArticles() {
            try {
                const response = await fetch(API_URL, {
                    headers: {
                        'Authorization': `Bearer ${ACCESS_TOKEN}`
                    }
                });
                const result = await response.json();
                
                if (result.success) {
                    allArticles = result.data;
                    applyFilters();
                } else {
                    showAlert(result.message || 'Failed to load articles', 'danger');
                }
            } catch (error) {
                console.error('Error:', error);
                showAlert('Could not connect to API', 'danger');
            }
        }

        function applyFilters() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const sort = document.getElementById('sortOrder').value;
            
            // Filter
            filteredArticles = allArticles.filter(a => 
                (a.newsTitle && a.newsTitle.toLowerCase().includes(search)) ||
                (a.headline && a.headline.toLowerCase().includes(search))
            );

            // Sort
            filteredArticles.sort((a, b) => {
                switch(sort) {
                    case 'date_desc': return new Date(b.createdDate) - new Date(a.createdDate);
                    case 'date_asc': return new Date(a.createdDate) - new Date(b.createdDate);
                    case 'title_asc': return (a.newsTitle || '').localeCompare(b.newsTitle || '');
                    default: return 0;
                }
            });

            currentPage = 1;
            renderTable();
        }

        function renderTable() {
            const pageSize = parseInt(document.getElementById('pageSize').value);
            const startIndex = (currentPage - 1) * pageSize;
            const endIndex = Math.min(startIndex + pageSize, filteredArticles.length);
            const pagedItems = filteredArticles.slice(startIndex, endIndex);

            const tbody = document.getElementById('articleTableBody');
            if (filteredArticles.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" class="text-center">No articles found.</td></tr>';
                renderPagination(0);
                return;
            }

            tbody.innerHTML = pagedItems.map((a, index) => {
                let actionTemplate = '';
                const isOffline = @(OfflineState.IsOffline.ToString().ToLower());
                
                if (!isOffline) {
                    actionTemplate = `
                        <button class="btn btn-sm btn-outline-info me-1" onclick="duplicateArticle('${a.newsArticleId}', this)" title="Duplicate">
                            <i class="bi bi-copy"></i>
                        </button>
                        <a href="/NewsArticle/Edit/${a.newsArticleId}" class="btn btn-sm btn-outline-primary">Edit</a>
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteArticle('${a.newsArticleId}')">Delete</button>
                    `;
                } else {
                    actionTemplate = `<span class="text-muted fst-italic"><i class="bi bi-lock"></i> Disabled</span>`;
                }

                return `<tr>
                    <td><small class="text-muted">${a.newsArticleId}</small></td>
                    <td><strong>${a.newsTitle || ''}</strong></td>
                    <td class="text-truncate" style="max-width: 200px;">${a.headline || ''}</td>
                    <td><span class="badge bg-light text-dark border">${a.categoryName || 'N/A'}</span></td>
                    <td>
                        <span class="badge ${a.newsStatus ? 'bg-success' : 'bg-secondary'}">
                            ${a.newsStatus ? 'Active' : 'Inactive'}
                        </span>
                    </td>
                    <td>${a.createdByName || '<span class="text-muted">N/A</span>'}</td>
                    <td>${a.createdDate ? new Date(a.createdDate).toLocaleDateString() : '-'}</td>
                    <td class="text-end">
                        ${actionTemplate}
                    </td>
                </tr>`;
            }).join('');

            document.getElementById('paginationInfo').innerText = 
                `Showing ${filteredArticles.length > 0 ? startIndex + 1 : 0} to ${endIndex} of ${filteredArticles.length} entries`;
            
            renderPagination(Math.ceil(filteredArticles.length / pageSize));
        }

        async function duplicateArticle(id, btn) {
            if (!confirm('Duplicate this article?')) return;
            
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const response = await fetch(`http://localhost:5039/api/newsarticles/${id}/duplicate`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${ACCESS_TOKEN}`
                    }
                });
                const result = await response.json();
                if (result.success) {
                    showAlert('Article duplicated successfully!', 'success');
                    await loadArticles(); // Refresh list
                } else {
                    showAlert(result.message || 'Duplicate failed', 'danger');
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            } catch (error) {
                showAlert('Error connecting to server', 'danger');
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        }

        function renderPagination(totalPages) {
            const controls = document.getElementById('paginationControls');
            controls.innerHTML = '';

            if (totalPages <= 1) return;

            // Prev
            controls.innerHTML += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${currentPage - 1})">Previous</a>
            </li>`;

            // Max 5 pages shown
            let start = Math.max(1, currentPage - 2);
            let end = Math.min(totalPages, start + 4);
            if (end - start < 4) start = Math.max(1, end - 4);

            for(let i = start; i <= end; i++) {
                controls.innerHTML += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                    <a class="page-link" href="#" onclick="changePage(${i})">${i}</a>
                </li>`;
            }

            // Next
            controls.innerHTML += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="changePage(${currentPage + 1})">Next</a>
            </li>`;
        }

        function changePage(p) {
            const pageSize = parseInt(document.getElementById('pageSize').value);
            const totalPages = Math.ceil(filteredArticles.length / pageSize);
            if (p < 1 || p > totalPages) return;
            currentPage = p;
            renderTable();
        }

        async function deleteArticle(id) {
            if (!confirm('Are you sure you want to delete this article?')) return;

            try {
                const response = await fetch(`http://localhost:5039/api/newsarticles/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${ACCESS_TOKEN}`
                    }
                });
                const result = await response.json();

                if (result.success) {
                    allArticles = allArticles.filter(a => a.newsArticleId !== id);
                    applyFilters();
                    showAlert('Delete success', 'success');
                } else {
                    showAlert(result.message || 'Delete failed', 'danger');
                }
            } catch (error) {
                showAlert('Error deleting article', 'danger');
            }
        }

        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            container.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            setTimeout(() => {
                const alert = container.querySelector('.alert');
                if (alert) {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }
            }, 3000);
        }
    </script>
}
