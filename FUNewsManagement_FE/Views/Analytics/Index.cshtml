@model FUNewsManagement_FE.Models.AnalyticsViewModel

@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2 class="h3 fw-bold mb-0">System Analytics</h2>
        <p class="text-muted mb-0">Overview of the FUNews Management statistics.</p>
    </div>
    <a asp-action="Export" class="btn btn-success d-flex align-items-center shadow-sm">
        <i class="bi bi-file-earmark-excel me-2"></i> Export Report
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
    </div>
}

<!-- Key Metric Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card glass text-center border-0 shadow-sm p-3">
            <h5 class="text-muted mb-2">Total Articles</h5>
            <h3 class="fw-bold text-primary mb-0">@Model.DashboardMetrics.TotalArticles</h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card glass text-center border-0 shadow-sm p-3">
            <h5 class="text-muted mb-2">Published</h5>
            <h3 class="fw-bold text-success mb-0">@Model.DashboardMetrics.PublishedArticles</h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card glass text-center border-0 shadow-sm p-3">
            <h5 class="text-muted mb-2">Drafts</h5>
            <h3 class="fw-bold text-warning mb-0">@Model.DashboardMetrics.DraftArticles</h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card glass text-center border-0 shadow-sm p-3">
            <h5 class="text-muted mb-2">Total Views</h5>
            <h3 class="fw-bold text-info mb-0">@Model.DashboardMetrics.TotalViewCount</h3>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Chart Section -->
    <div class="col-lg-6">
        <div class="card glass border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">Articles by Category</h5>
            </div>
            <div class="card-body">
                @if (Model.DashboardMetrics.ByCategory.Any())
                {
                    <canvas id="categoryChart" style="max-height: 300px;"></canvas>
                }
                else
                {
                    <p class="text-muted">No category data available.</p>
                }
            </div>
        </div>
    </div>

    <!-- Trending Articles Table -->
    <div class="col-lg-6">
        <div class="card glass border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 pt-4 pb-0">
                <h5 class="fw-bold mb-0">Top Trending Articles</h5>
            </div>
            <div class="card-body">
                @if (Model.TrendingArticles.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-borderless align-middle mb-0">
                            <thead class="text-muted">
                                <tr>
                                    <th>Title</th>
                                    <th>Category</th>
                                    <th class="text-end">Views</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.TrendingArticles)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold text-truncate" style="max-width: 200px;" title="@item.NewsTitle">@item.NewsTitle</div>
                                            <div class="small text-muted">@item.AuthorName</div>
                                        </td>
                                        <td><span class="badge bg-secondary">@item.CategoryName</span></td>
                                        <td class="text-end fw-bold text-info">@item.ViewCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No trending data available.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('categoryChart');
            if (ctx) {
                // Parse model data directly to JS Arrays using Json serialization securely
                const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DashboardMetrics.ByCategory.Select(c => c.CategoryName)));
                const dataPoints = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DashboardMetrics.ByCategory.Select(c => c.Count)));

                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Articles Count',
                            data: dataPoints,
                            backgroundColor: [
                                '#38bdf8', '#fbbf24', '#f87171', '#34d399', '#a78bfa', '#fb923c'
                            ],
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    color: '#e5e7eb'
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
